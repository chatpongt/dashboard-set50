# Copy this file to .streamlit/secrets.toml and fill in your keys.
# secrets.toml is gitignored — never commit real keys.

# Perplexity AI (required)
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY = "pplx-..."

# Supabase (optional — enables history storage)
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL      = "https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY = "eyJ..."

# Resend (optional — enables email reports)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY = "re_..."

# Resend sender address (optional)
# Use "onboarding@resend.dev" for testing, or your verified domain for production.
# e.g. "SET50 Dashboard <dashboard@yourdomain.com>"
RESEND_FROM = "onboarding@resend.dev"
